  "item": [
    {
      "name": "Get Subscription Plans",
      "request": {
        "method": "GET",
        "header": [],
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{token}}",
              "type": "string"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}{{apiPrefix}}/subscription/plans",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "{{apiPrefix}}",
            "subscription",
            "plans"
          ]
        },
        "description": "Fetch subscription plans with admin-set price plus Apple and Google store prices."
      },
      "response": [
        {
          "name": "Sample Response",
          "originalRequest": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/subscription/plans"
            }
          },
          "status": "OK",
          "code": 200,
          "_postman_previewlanguage": "json",
          "body": "{\n  \"plans\": [\n    {\n      \"planType\": \"monthly\",\n      \"interval\": \"month\",\n      \"label\": \"Monthly Plan\",\n      \"prices\": {\n        \"admin\": {\n          \"amount\": 9.99,\n          \"amountCents\": 999,\n          \"currency\": \"usd\"\n        },\n        \"apple\": {\n          \"amount\": 6.99,\n          \"currency\": \"USD\"\n        },\n        \"google\": {\n          \"amount\": 7.99,\n          \"currency\": \"USD\"\n        }\n      }\n    },\n    {\n      \"planType\": \"yearly\",\n      \"interval\": \"year\",\n      \"label\": \"Yearly Plan\",\n      \"prices\": {\n        \"admin\": {\n          \"amount\": 99.99,\n          \"amountCents\": 9999,\n          \"currency\": \"usd\"\n        },\n        \"apple\": {\n          \"amount\": 34.99,\n          \"currency\": \"USD\"\n        },\n        \"google\": {\n          \"amount\": 39.99,\n          \"currency\": \"USD\"\n        }\n      }\n    }\n  ]\n}"
        }
      ]
    },
